# AI report (optional) — Google Gemini (required on production if you want the AI tab to work)
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key
# Aliases: GEMINIAPI_KEY=  or  GOOGLE_GENERATIVE_AI_API_KEY=
# Default model in code: gemini-2.5-pro. Try gemini-2.5-flash for speed/cost.
# GEMINI_MODEL=gemini-2.5-flash

# Jira — log findings as issues (optional). Token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_HOST=https://your-company.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=QA
# JIRA_ISSUE_TYPE=Bug

# --- Local dev (macOS / Windows): prefer system Chrome ---
PLAYWRIGHT_CHROMIUM_CHANNEL=chrome
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Pin browser downloads to this project (recommended with PLAYWRIGHT_BROWSERS_PATH=0 + npm run playwright:install:project)
PLAYWRIGHT_BROWSERS_PATH=0

# --- Production (Docker / Render / Railway): do not set PLAYWRIGHT_CHROMIUM_CHANNEL; the image uses bundled Chromium. ---

# --- Optional: Adobe I/O (Analytics 2.0 + Tags Reactor) — sidebar “Adobe Cloud” panel ---
# Create a project: https://developer.adobe.com/console Add “Adobe Analytics” + “Adobe Experience Platform Launch API”.
# OAuth: obtain a bearer access token (short-lived) or use a service integration; paste token below. Never commit real tokens.
# ADOBE_ACCESS_TOKEN=
# ADOBE_API_KEY=          # OAuth Client ID (same as x-api-key header)
# ADOBE_ANALYTICS_GLOBAL_COMPANY_ID=   # Global company id for analytics.adobe.io/api/{id}/…
# ADOBE_IMS_ORG_ID=         # x-gw-ims-org-id for Reactor (Tags) calls
# ADOBE_TAGS_PROPERTY_ID=   # Default Launch property (PR…) for rules/extensions buttons
